{
  "manifest_version": 3,
  "name": "Omni - Voice AI Assistant",
  "version": "1.0.0",
  "description": "Voice-controlled AI assistant that learns and grows. Control your browser, summarize content, automate tasks.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "contextMenus",
    "webNavigation",
    "bookmarks",
    "history",
    "downloads",
    "notifications",
    "clipboardWrite",
    "clipboardRead",
    "cookies",
    "tabGroups",
    "sessions",
    "topSites",
    "webRequest",
    "alarms",
    "idle",
    "power",
    "system.display",
    "system.storage",
    "desktopCapture",
    "offscreen",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "Open Omni"
    },
    "voice_command": {
      "suggested_key": {
        "default": "Ctrl+Shift+Space",
        "mac": "Command+Shift+Space"
      },
      "description": "Activate voice command"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
